# OpenAI-compatible endpoint (used by OpenApiSdkClient and OpenApiRawClient)
# Azure OpenAI example:
# OPENAPI_BASE_URL=https://your-foundry-resource.openai.azure.com/openai/deployments/your-deployment
# Local mock server example:
# OPENAPI_BASE_URL=http://127.0.0.1:8765/v1
OPENAPI_BASE_URL=https://your-foundry-resource.openai.azure.com/openai/deployments/your-deployment
OPENAPI_API_KEY=your-openai-compatible-api-key
OPENAPI_MODEL=your-deployment-or-model-name
